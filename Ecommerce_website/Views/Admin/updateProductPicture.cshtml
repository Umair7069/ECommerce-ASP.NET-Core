@model Ecommerce_website.Models.Product

@{
    ViewData["Title"] = "update product picture";
}

<h1>Edit</h1>

<h4>Customer</h4>
<p style="color:red">@TempData["sizeerror"]</p>
<p style="color:red">@TempData["exterror"]</p>
<hr />
<div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-8">
        <form asp-action="updateProductPicture" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="product_id" />
            <div class="form-group">
                
                <input hidden asp-for="product_name" class="form-control" value="@Model.product_name" />
               
            </div>
            <div class="form-group">

                <input hidden asp-for="product_price" class="form-control" value="@Model.product_price" />

            </div>
            <div class="form-group">

                <input hidden asp-for="product_description" class="form-control" value="@Model.product_description />

            </div>
            <div class="form-group">

                <input hidden asp-for="cat_id" class="form-control" value="@Model.cat_id"/>

            </div>
           
            <div class="form-group">
                <label asp-for="product_image" class="control-label">Image</label>
                <img src="" />
                <input type="file" asp-for="product_image" class="form-control" />
                <span asp-validation-for="product_image" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Update Picture" class="btn btn-primary" />
            </div>

        </form>
    </div>
    <div class="col-md-2"></div>
</div>

<div>
    <a asp-action="updateProduct">Back to List</a>
</div>




