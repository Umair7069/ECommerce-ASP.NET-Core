@model IEnumerable<Ecommerce_website.Models.Category>

@{
    ViewData["Title"] = "fetchcategory";
}

<<h1 class="mb-4 text-center">Category List</h1>

<div class="d-flex justify-content-between mb-3">
    <a asp-action="AddCategory" class="btn btn-success">+ Add New Category</a>
</div>

<div class="table-responsive shadow-sm rounded text-center mt-2" style="max-height: 500px; overflow-y: auto;">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.category_id)</th>
                <th>@Html.DisplayNameFor(model => model.category_name)</th>
                
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.category_id)</td>
                    <td>@Html.DisplayFor(modelItem => item.category_name)</td>
                    

                    <td class="text-center">
                        <a asp-action="updateCategory" asp-route-id="@item.category_id" class="btn btn-sm btn-primary">Update</a>
                        
                        <a asp-action="DeleteCategoryPermission" asp-route-id="@item.category_id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


