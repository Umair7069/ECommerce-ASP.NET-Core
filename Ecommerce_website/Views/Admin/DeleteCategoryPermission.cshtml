@model Ecommerce_website.Models.Category

@{
    ViewData["Title"] = "Edit";
}
  
<h2>Delete Category</h2>

<div class="row">
    <div class="col-md-2"></div>
    <div class="col-md-8">
        <ul class="list-group my-3">
            <li class="list-group-item">Category Id: @Model.category_id</li>
            <li class="list-group-item">Category Name: @Model.category_name</li>
        </ul>
        <a href="@Url.Action("deleteCategoryConfirmed","Admin",new{id=Model.category_id})" class="btn btn-danger">Delete confirm </a>
        <a href="@Url.Action("fetchcategory","Admin")" class="btn btn-warning">Back to List </a>
    </div>
    <div class="col-md-2"></div>
</div>




