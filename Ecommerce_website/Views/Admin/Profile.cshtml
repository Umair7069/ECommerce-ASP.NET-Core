@model Ecommerce_website.Models.Admin

@{
    ViewData["Title"] = "Admin Profile";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-lg p-4 rounded-4" style="width: 450px; background-color: #f8f9fa;">
        <div class="text-center mb-4">
            <img src="~/Images/@Model.admin_image" alt="Admin Avatar" class="rounded-circle shadow-sm mb-3" width="100" height="100" />
            <h2 class="fw-bold text-primary">Admin Profile</h2>
            <p class="text-muted">Update your profile information below</p>
        </div>
        <p style="color:red">@TempData["sizeerror"]</p>
        <p style="color:red">@TempData["exterror"]</p>

        <form asp-action="Profile" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                
                <input  type="hidden" asp-for="admin_id" class="form-control rounded-pill border-primary" value="@Model.admin_id" />
                <span asp-validation-for="admin_id" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="admin_name" class="form-label fw-semibold">Admin Name</label>
                <input asp-for="admin_name" class="form-control rounded-pill border-primary" value="@Model.admin_name" />
                 <span asp-validation-for="admin_name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="admin_email" class="form-label fw-semibold">Email</label>
                <input asp-for="admin_email" type="email" class="form-control rounded-pill border-primary" value="@Model.admin_email" />
                <span asp-validation-for="admin_email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="admin_password" class="form-label fw-semibold">Password</label>
                <input asp-for="admin_password" type="password" class="form-control rounded-pill border-primary" value="@Model.admin_password" />
                <span asp-validation-for="admin_password" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="admin_image" class="form-label fw-semibold">Image</label>
                <img src=""/>
                <input asp-for="admin_image" type="file" class="form-control rounded-pill border-primary" value="@Model.admin_image" />
                <span asp-validation-for="admin_image" class="text-danger"></span>
                
            </div>

            <div class="d-grid">
                <input type="submit" value="Update  Profile" class="btn btn-primary rounded-pill py-2 shadow-sm" />
            </div>
        </form>

        <div class="text-center mt-4">
            <a asp-action="Index" class="text-decoration-none text-secondary fw-semibold">
                ← Back to Dashboard
            </a>
        </div>
    </div>
</div>
